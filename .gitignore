# Local .terraform directory
.terraform/

# Terraform lock file (optional to commit, but commonly ignored)
.terraform.lock.hcl

# Terraform state files
terraform.tfstate
terraform.tfstate.backup

# Crash log
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
